# ── Required ──────────────────────────────────────────────────────────────────
# URL of your auth-service instance — used to fetch the ES256 public key (JWKS) and validate the issuer
AUTH_SERVICE_URL=http://localhost:8703

# ── AI Provider API Keys (set the ones you use) ──────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE_NAME=
AZURE_OPENAI_ENDPOINT=

# ── Free-Tier Provider API Keys (optional — can also be supplied per-request) ─
GROQ_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
CEREBRAS_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=

# ── Model overrides (optional — defaults shown) ───────────────────────────────
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Ollama (local or cloud — uses OpenAI-compatible API) ─────────────────────
# For local: point to your Ollama instance (default)
# For cloud: set to your Ollama Cloud endpoint (e.g. https://your-endpoint.ollama.ai/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_VISION_MODEL=llava
OLLAMA_TEXT_MODEL=llama3.2

# ── Server ───────────────────────────────────────────────────────────────────
AI_WRAP_PORT=8090
AI_WRAP_ALLOWED_ORIGIN=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
AI_WRAP_RATE_LIMIT_RPM=30
AI_WRAP_RATE_LIMIT_RPD=1000

# ── Size limits ───────────────────────────────────────────────────────────────
AI_WRAP_MAX_BODY_SIZE=50M
AI_WRAP_MAX_UPLOAD_BYTES=20971520
AI_WRAP_MAX_PROMPT_CHARS=200000

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_DIR=logs
