package com.adars.aiwrap.provider.ollama

import dev.langchain4j.data.message.ImageContent
import dev.langchain4j.data.message.TextContent
import dev.langchain4j.data.message.UserMessage
import dev.langchain4j.model.chat.ChatLanguageModel
import io.quarkiverse.langchain4j.ModelName
import jakarta.enterprise.context.ApplicationScoped
import jakarta.inject.Inject

/**
 * OCR service using a locally-running vision model via Ollama (e.g. LLaVA, Qwen-VL).
 */
@ApplicationScoped
class OllamaOcrService {

    @Inject
    @field:ModelName("ollama-vision")
    lateinit var model: ChatLanguageModel

    private val prompt: String by lazy {
        javaClass.classLoader
            .getResourceAsStream("prompts/ocr-receipt-structured.txt")
            ?.bufferedReader()?.readText()
            ?: error("prompts/ocr-receipt-structured.txt not found on classpath")
    }

    fun extractReceiptJson(imageBase64: String, mimeType: String): String {
        val userMessage = UserMessage.from(
            TextContent.from(prompt),
            ImageContent.from(imageBase64, mimeType)
        )
        val response = model.chat(userMessage)
        return response.aiMessage().text() ?: ""
    }
}
